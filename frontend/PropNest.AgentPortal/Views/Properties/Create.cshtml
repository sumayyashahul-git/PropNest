@model PropNest.AgentPortal.Models.CreatePropertyViewModel

<!DOCTYPE html>
<html>
<head>
    <title>New Listing — PropNest</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="min-h-screen flex flex-col bg-gray-50">

<!-- Header -->
<header class="bg-gray-900 px-10 h-16 flex items-center justify-between shadow-lg">
    <span class="text-red-400 text-xl font-bold">🏠 PropNest Agent</span>
    <nav class="flex items-center gap-6">
        <span class="text-gray-400 text-sm">👤 @ViewBag.UserName</span>
        <a href="/Properties"
            class="text-gray-300 hover:text-white text-sm transition-colors">
            My Listings
        </a>
        <a href="/Account/Logout"
            class="border border-red-500 text-red-400 text-sm px-4 py-2 rounded-lg">
            Logout
        </a>
    </nav>
</header>

<!-- Main -->
<main class="flex-1 px-10 py-8">
    <div class="max-w-2xl mx-auto">

        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">New Listing</h1>
            <p class="text-gray-500 mt-1">Add a new property to PropNest</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg mb-6 text-sm">
                @ViewBag.Error
            </div>
        }

        <form method="post" class="bg-white rounded-2xl shadow-sm p-8 space-y-5">

            <div class="grid grid-cols-1 gap-5">

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                    <input asp-for="Title" placeholder="Luxury 2BR in Downtown Dubai"
                        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <textarea asp-for="Description" rows="3" placeholder="Describe the property..."
                        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Price (AED)</label>
                        <input asp-for="Price" type="number" placeholder="2500000"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Service Charge (AED)</label>
                        <input asp-for="ServiceCharge" type="number" placeholder="25000"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
                        <input asp-for="Location" placeholder="Downtown Dubai"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Community</label>
                        <input asp-for="Community" placeholder="Burj Khalifa District"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Property Type</label>
                        <select asp-for="Type"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 bg-white">
                            <option value="0">Apartment</option>
                            <option value="1">Villa</option>
                            <option value="2">Townhouse</option>
                            <option value="3">Penthouse</option>
                            <option value="4">Studio</option>
                            <option value="5">Office</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Listing Type</label>
                        <select asp-for="ListingType"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 bg-white">
                            <option value="0">For Sale</option>
                            <option value="1">For Rent</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Emirate</label>
                        <select asp-for="Emirate"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 bg-white">
                            <option value="Dubai">Dubai</option>
                            <option value="Abu Dhabi">Abu Dhabi</option>
                            <option value="Sharjah">Sharjah</option>
                            <option value="Ajman">Ajman</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bedrooms</label>
                        <input asp-for="Bedrooms" type="number" placeholder="2"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bathrooms</label>
                        <input asp-for="Bathrooms" type="number" placeholder="2"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Area (sqft)</label>
                        <input asp-for="AreaSqFt" type="number" placeholder="1200"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400" />
                    </div>
                </div>

                <div class="flex gap-6">
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input asp-for="HasParking" type="checkbox" class="rounded" />
                        Parking
                    </label>
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input asp-for="HasPool" type="checkbox" class="rounded" />
                        Pool
                    </label>
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input asp-for="HasGym" type="checkbox" class="rounded" />
                        Gym
                    </label>
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input asp-for="IsFurnished" type="checkbox" class="rounded" />
                        Furnished
                    </label>
                </div>

            </div>

            <div class="flex gap-4 pt-4">
                <button type="submit"
                    class="bg-red-500 hover:bg-red-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors text-sm">
                    Publish Listing
                </button>
                <a href="/Properties"
                    class="border border-gray-300 text-gray-600 hover:bg-gray-50 font-semibold px-8 py-3 rounded-lg transition-colors text-sm">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</main>

<!-- Footer -->
<footer class="bg-gray-900 text-gray-400 px-10 py-5 flex justify-between text-sm">
    <span>© 2024 PropNest — Agent Portal</span>
    <span>UAE Real Estate Platform</span>
</footer>

</body>
</html>
